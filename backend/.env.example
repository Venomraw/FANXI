# ── Required ──────────────────────────────────────────────────────────────
FOOTBALL_API_KEY=your-api-sports-key
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
SECRET_KEY=generate-a-strong-random-key

# ── Environment ──────────────────────────────────────────────────────────
FANXI_ENV=development          # development | production
FANXI_RELEASE=1.0.0            # version tag for Sentry releases
FANXI_WORKERS=4                # uvicorn worker count
FANXI_PORT=8000                # local dev only — Railway/Render inject $PORT
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ── Sentry (optional — enables error tracking) ──────────────────────────
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1         # 0.0 to 1.0

# ── CORS (production only) ──────────────────────────────────────────────
FANXI_CORS_ORIGIN=             # extra allowed origin e.g. https://custom-domain.com

# ── OAuth ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── External APIs ────────────────────────────────────────────────────────
FOOTBALL_DATA_API_KEY=
GROQ_API_KEY=
GUARDIAN_API_KEY=
NEWSDATA_API_KEY=
YOUTUBE_API_KEY=
NEWS_API_KEY=

# ── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
FRONTEND_URL=http://localhost:3000
